{
  "name": "puddly",
  "version": "1.0.0",
  "description": "Puddly - A cute desktop hydration companion",
  "main": "main/main.js",
  "author": "Pratiti Paul",
  "license": "MIT",
  "type": "commonjs",

  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pratiti-paul/Puddly.git"
  },

  "homepage": "https://github.com/Pratiti-paul/Puddly#readme",

  "bugs": {
    "url": "https://github.com/Pratiti-paul/Puddly/issues"
  },

  "keywords": [
    "electron",
    "desktop",
    "hydration",
    "water-reminder",
    "desktop-companion",
    "desktop-pet",
    "productivity",
    "wellness",
    "puddly"
  ],

  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:all": "electron-builder --mac --win"
  },

  "build": {
    "appId": "com.pratitipaul.puddly",
    "productName": "Puddly",

    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },

    "files": [
      "main/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json",
      "!dist/**",
      "!node_modules/.cache/**"
    ],

    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.healthcare-fitness",
      "artifactName": "Puddly-${version}-${arch}.${ext}"
    },

    "dmg": {
      "title": "Puddly Installer",
      "icon": "assets/icon.icns"
    },

    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Puddly-Setup-${version}.${ext}"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Puddly"
    }
  },

  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12"
  }
}